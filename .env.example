# ──────────────────────────────────────────────────────────────
# StudySync – environment variable template
# Copy this file to .env and fill in your real values.
# NEVER commit the filled-in .env to version control.
# ──────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────
# Choose "openai" (default) or "anthropic"
LLM_PROVIDER=openai

# OpenAI API key (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic API key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Model name to use for extraction
# OpenAI examples:   gpt-4o-mini  |  gpt-4o  |  gpt-4-turbo
# Anthropic examples: claude-3-haiku-20240307  |  claude-3-5-sonnet-20241022
LLM_MODEL=gpt-4o-mini

# ── Database (PostgreSQL via Render) ──────────────────────────
# Render provides this automatically; set manually for local dev
DATABASE_URL=postgresql://user:password@host:5432/studysync

# ── Server ────────────────────────────────────────────────────
# Port the Uvicorn server listens on (Render injects PORT automatically)
PORT=8000

# Set to "true" for hot-reload during local development
RELOAD=true

# ── Security ──────────────────────────────────────────────────
# Secret key used for signing tokens (generate with: openssl rand -hex 32)
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
